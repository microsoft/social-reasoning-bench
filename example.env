# Model provider API keys — uncomment and fill in the ones you use.

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# PHYAGI_API_KEY=

# Azure pool config directory (populated by sage-azure-pool)
# SAGE_AZURE_POOL_PATH=configs/azure_pool

# Concurrency tuning (see README § Concurrency and Throughput)
# SAGE_LLM_SIZE=64
# SAGE_LLM_TASK_SIZE=5
# SAGE_METRICS_INTERVAL=120
